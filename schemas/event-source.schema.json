{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventSource",
  "type": "object",
  "required": ["id", "name", "category", "events"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "唯一标识，全小写+连字符，不含年份"
    },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["exam", "gaming", "sports", "shopping", "entertainment", "other"]
    },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "maintainer": { "type": "string", "enum": ["official", "community"] },
    "last_updated": { "type": "string", "format": "date" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "date", "type", "year", "timezone", "last_verified", "verified_by"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "time": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
          "timezone": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["deadline", "event", "range", "announcement"]
          },
          "year": { "type": "integer" },
          "description": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "status": {
            "type": "string",
            "enum": ["planned", "confirmed", "active", "completed"]
          },
          "last_verified": { "type": "string", "format": "date" },
          "verified_by": { "type": "string", "enum": ["official", "community", "auto"] },
          "details": {
            "type": "object",
            "description": "事件详情键值对，用于日历 tooltip 和详情页展示。键名即标签，值即内容。",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
