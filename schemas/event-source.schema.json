{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventSource",
  "type": "object",
  "required": ["id", "name", "category", "events"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "唯一标识，全小写+连字符，不含年份"
    },
    "name": { "type": "string" },
    "name_en": { "type": "string", "description": "英文名称" },
    "category": {
      "type": "string",
      "enum": ["exam", "gaming", "sports", "shopping", "entertainment", "holidays", "other"]
    },
    "description": { "type": "string" },
    "description_en": { "type": "string", "description": "英文描述" },
    "subcategory": { "type": "string" },
    "subcategory_en": { "type": "string", "description": "英文子分类" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "tags_en": { "type": "array", "items": { "type": "string" }, "description": "英文标签" },
    "icon": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "maintainer": { "type": "string", "enum": ["official", "community"] },
    "subscriber_count": { "type": "integer" },
    "rating": { "type": "number" },
    "rating_count": { "type": "integer" },
    "last_updated": { "type": "string", "format": "date" },
    "version": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "date", "type", "year", "timezone", "last_verified", "verified_by"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_en": { "type": "string", "description": "英文事件名" },
          "date": { "type": "string", "format": "date" },
          "time": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
          "timezone": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["deadline", "event", "range", "announcement"]
          },
          "year": { "type": "integer" },
          "description": { "type": "string" },
          "description_en": { "type": "string", "description": "英文事件描述" },
          "url": { "type": "string", "format": "uri" },
          "status": {
            "type": "string",
            "enum": ["planned", "confirmed", "active", "completed"]
          },
          "last_verified": { "type": "string", "format": "date" },
          "verified_by": { "type": "string", "enum": ["official", "community", "auto"] },
          "details": {
            "type": "object",
            "description": "事件详情键值对，用于日历 tooltip 和详情页展示。键名即标签，值即内容。",
            "additionalProperties": { "type": "string" }
          },
          "teams": {
            "type": "object",
            "description": "体育赛事的结构化主客队信息，用于生成球队专属订阅日历",
            "required": ["home", "away"],
            "properties": {
              "home": { "$ref": "#/definitions/team" },
              "away": { "$ref": "#/definitions/team" }
            },
            "additionalProperties": false
          },
          "result": {
            "type": "object",
            "description": "已结束体育赛事的结构化赛果",
            "required": ["home_score", "away_score", "winner", "status"],
            "properties": {
              "home_score": { "type": "integer" },
              "away_score": { "type": "integer" },
              "winner": { "type": "string", "enum": ["home", "away", "draw"] },
              "status": { "type": "string" }
            },
            "additionalProperties": false
          },
          "games": {
            "type": "array",
            "description": "游戏列表（仅 gaming 分类事件源使用），描述本周/当期免费或促销的具体游戏",
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "description": "游戏名称" },
                "description": { "type": "string", "description": "游戏简介" },
                "cover_url": { "type": "string", "format": "uri", "description": "游戏封面图 URL" },
                "original_price": { "type": "string", "description": "原价（如 ¥168.00），免费期间可能无法获取" },
                "store_url": { "type": "string", "format": "uri", "description": "商店页面链接" }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "team": {
      "type": "object",
      "required": ["id", "code", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "球队稳定 ID，用于 iCal 文件名，如 lal、ars"
        },
        "code": {
          "type": "string",
          "description": "赛事方常用球队缩写或短码，如 LAL、ARS"
        },
        "name": {
          "type": "string",
          "description": "球队展示名"
        },
        "name_en": {
          "type": "string",
          "description": "球队英文名"
        }
      },
      "additionalProperties": false
    }
  }
}
