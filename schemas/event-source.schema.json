{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventSource",
  "type": "object",
  "required": ["id", "name", "category", "events"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "唯一标识，全小写+连字符，不含年份"
    },
    "name": { "type": "string" },
    "name_en": { "type": "string", "description": "英文名称" },
    "category": {
      "type": "string",
      "enum": ["exam", "gaming", "sports", "shopping", "entertainment", "holidays", "other"]
    },
    "description": { "type": "string" },
    "description_en": { "type": "string", "description": "英文描述" },
    "subcategory": { "type": "string" },
    "subcategory_en": { "type": "string", "description": "英文子分类" },
    "exam_classification": {
      "type": "object",
      "description": "考试分类结构化字段。只用于 exam 分类；key 使用英文，展示文案由各端本地化。",
      "required": ["audiences", "tracks"],
      "properties": {
        "audiences": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["student", "professional"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "tracks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "admissions",
              "campus-language",
              "study-abroad-language",
              "public-service",
              "finance-accounting",
              "law",
              "education",
              "it",
              "healthcare",
              "engineering-construction",
              "language-translation",
              "culture-media",
              "social-service"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "tags_en": { "type": "array", "items": { "type": "string" }, "description": "英文标签" },
    "icon": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "attribution": { "type": "string", "description": "第三方数据源署名要求" },
    "maintainer": { "type": "string", "enum": ["official", "community"] },
    "subscriber_count": { "type": "integer" },
    "rating": { "type": "number" },
    "rating_count": { "type": "integer" },
    "last_updated": { "type": "string", "format": "date" },
    "version": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "date", "type", "year", "timezone", "last_verified", "verified_by"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_en": { "type": "string", "description": "英文事件名" },
          "date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "time": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
          "end_time": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
          "timezone": { "type": "string" },
          "time_kind": {
            "type": "string",
            "description": "事件时间语义：date/date_range 为官方日期，不做本地时区换算；datetime/datetime_range 为具体瞬间或时间段，可按用户本地时区展示。",
            "enum": ["date", "datetime", "date_range", "datetime_range"]
          },
          "type": {
            "type": "string",
            "enum": ["deadline", "event", "range", "announcement"]
          },
          "year": { "type": "integer" },
          "description": { "type": "string" },
          "description_en": { "type": "string", "description": "英文事件描述" },
          "url": { "type": "string", "format": "uri" },
          "status": {
            "type": "string",
            "enum": ["planned", "confirmed", "active", "completed"]
          },
          "last_verified": { "type": "string", "format": "date" },
          "verified_by": { "type": "string", "enum": ["official", "community", "auto"] },
          "details": {
            "type": "object",
            "description": "事件详情键值对，用于日历 tooltip 和详情页展示。键名即标签，值即内容。",
            "additionalProperties": { "type": "string" }
          },
          "details_en": {
            "type": "object",
            "description": "英文事件详情键值对。",
            "additionalProperties": { "type": "string" }
          },
          "game": {
            "$ref": "#/definitions/gameEventMeta",
            "description": "游戏服务型事件的结构化元信息，如版本、阶段、官方公告来源。"
          },
          "banners": {
            "type": "array",
            "description": "卡池/祈愿/跃迁结构化信息，适用于抽卡类游戏。",
            "items": { "$ref": "#/definitions/gameBanner" }
          },
          "teams": {
            "type": "object",
            "description": "体育赛事的结构化主客队信息，用于生成球队专属订阅日历",
            "required": ["home", "away"],
            "properties": {
              "home": { "$ref": "#/definitions/team" },
              "away": { "$ref": "#/definitions/team" }
            },
            "additionalProperties": false
          },
          "result": {
            "type": "object",
            "description": "已结束体育赛事的结构化赛果",
            "required": ["home_score", "away_score", "winner", "status"],
            "properties": {
              "home_score": { "type": "integer" },
              "away_score": { "type": "integer" },
              "winner": { "type": "string", "enum": ["home", "away", "draw"] },
              "status": { "type": "string" }
            },
            "additionalProperties": false
          },
          "games": {
            "type": "array",
            "description": "游戏列表（仅 gaming 分类事件源使用），描述本周/当期免费或促销的具体游戏",
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "description": "游戏名称" },
                "title_zh": { "type": "string", "description": "中文游戏名称" },
                "title_en": { "type": "string", "description": "英文游戏名称" },
                "description": { "type": "string", "description": "游戏简介" },
                "cover_url": { "type": "string", "format": "uri", "description": "游戏封面图 URL" },
                "original_price": { "type": "string", "description": "原价（如 ¥168.00），免费期间可能无法获取" },
                "store_url": { "type": "string", "format": "uri", "description": "商店页面链接" },
                "platforms": {
                  "type": "array",
                  "description": "发售平台列表，适用于游戏发售日历",
                  "items": { "type": "string" }
                },
                "rawg_id": { "type": "string", "description": "RAWG 游戏 ID" },
                "rawg_rating": { "type": "number", "description": "RAWG 用户评分（0-5）" },
                "metacritic": { "type": "number", "description": "Metacritic 评分" }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "gameEventMeta": {
      "type": "object",
      "required": ["game_id", "source_kind"],
      "properties": {
        "game_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "游戏事件源 ID，如 genshin-impact、honkai-star-rail。"
        },
        "provider": {
          "type": "string",
          "description": "数据提供方或平台，如 hoyoverse、kuro、community。"
        },
        "source_kind": {
          "type": "string",
          "enum": ["version", "version_update", "banner", "activity", "announcement", "forecast", "other"]
        },
        "version": { "type": "string" },
        "phase": {
          "type": "string",
          "description": "版本内阶段，如 phase1、phase2、phase3。"
        },
        "activity_name": { "type": "string" },
        "source_content_id": { "type": "string" },
        "source_title": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "gameBanner": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "description": "卡池/祈愿/跃迁名称" },
        "type": {
          "type": "string",
          "enum": ["character", "weapon", "light_cone", "bangboo", "standard", "collaboration", "other"]
        },
        "phase": { "type": "string" },
        "featured_5": {
          "type": "array",
          "items": { "$ref": "#/definitions/gameBannerItem" }
        },
        "featured_4": {
          "type": "array",
          "items": { "$ref": "#/definitions/gameBannerItem" }
        },
        "source_content_id": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "gameBannerItem": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string", "description": "称号，如恣锐锋镞。" },
        "kind": {
          "type": "string",
          "enum": ["character", "weapon", "light_cone", "bangboo", "other"]
        },
        "rarity": { "type": "integer", "minimum": 1, "maximum": 6 },
        "element": { "type": "string" },
        "path": { "type": "string", "description": "命途/职业/属性分类。" },
        "weapon_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "team": {
      "type": "object",
      "required": ["id", "code", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "球队稳定 ID，用于 iCal 文件名，如 lal、ars"
        },
        "code": {
          "type": "string",
          "description": "赛事方常用球队缩写或短码，如 LAL、ARS"
        },
        "name": {
          "type": "string",
          "description": "球队展示名"
        },
        "name_en": {
          "type": "string",
          "description": "球队英文名"
        }
      },
      "additionalProperties": false
    }
  }
}
